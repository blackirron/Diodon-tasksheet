# Copy this file to `.env` and fill in real values.
# NEVER commit the actual `.env` file — only this example file goes to GitHub.

APP_NAME=my-app
ENVIRONMENT=development

# Which LLM provider ask_claude() calls. "groq" = free tier, no card needed.
# Switch to "anthropic" once you have a paid Claude key — nothing else changes.
LLM_PROVIDER=groq

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk-your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Any random long string — this is what protects your endpoints in production
API_AUTH_TOKEN=change-me-to-something-random

# Comma-separated list of frontend URLs allowed to call this API.
# Use * only for local development, never in production.
ALLOWED_ORIGINS=*
